# Producción: https://ondeck.nodo-digital.com (raíz del subdominio, Hostinger)
# Copia este archivo como `.htaccess` en el servidor.
#
# Desarrollo local: usa `.htaccess.local` (renómbralo a `.htaccess` en localhost).

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Forzar HTTPS
    RewriteCond %{HTTPS} !=on
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # index.php -> / (canonical)
    RewriteCond %{THE_REQUEST} \s/+index\.php[\s?] [NC]
    RewriteRule ^index\.php$ / [R=301,L]

    # *.php -> misma ruta sin extensión
    RewriteCond %{THE_REQUEST} \s/+(.+?)\.php[\s?] [NC]
    RewriteRule ^(.+)\.php$ /$1 [R=301,L]

    # /privacy, /terms, etc. -> archivo .php correspondiente
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^([^/]+)/?$ $1.php [L,QSA]
</IfModule>
