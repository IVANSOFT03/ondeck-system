# MySQL — usar los datos del panel de Hostinger
DB_HOST=localhost
DB_NAME=nombre_de_tu_base
DB_USER=usuario_mysql
DB_PASS=password_mysql

# Google Drive
GOOGLE_SERVICE_ACCOUNT_PATH=/ruta/absoluta/credentials/google-service-account.json
GOOGLE_DRIVE_FOLDER_ID=ID_de_la_carpeta_raiz_en_drive

# TikTok
TIKTOK_CLIENT_KEY=tu_client_key
TIKTOK_CLIENT_SECRET=tu_client_secret
TIKTOK_ACCESS_TOKEN=token_inicial
TIKTOK_REFRESH_TOKEN=refresh_token_inicial

# Email
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=tu@gmail.com
MAIL_PASS=app_password_de_gmail
MAIL_FROM_NAME=TikTok Colaborativo
