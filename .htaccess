Options -Indexes

<IfModule mod_rewrite.c>
  RewriteEngine On
  # API pública (document root = esta carpeta tiktok-system)
  RewriteRule ^api/stats/?$ src/api/stats.php [L,QSA]
  RewriteRule ^auth/tiktok/login/?$ public/auth/tiktok/login/index.php [L,QSA]
  RewriteRule ^auth/tiktok/callback/?$ public/auth/tiktok/callback/index.php [L,QSA]
  RewriteRule ^config/ - [F,L]
  RewriteRule ^src/ - [F,L]
  RewriteRule ^vendor/ - [F,L]
</IfModule>

